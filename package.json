  },
  "dependencies": {
    "@loadwhiz/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@loadwhiz/config": "workspace:*",
