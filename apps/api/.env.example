APP_NAME="LoadWhiz"
ENVIRONMENT=development
DEBUG=true

REDIS_HOST=localhost
REDIS_PORT=6379

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/loadwhiz

JWT_SECRET=super-secret-key
JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
INVITE_TOKEN_EXPIRE_DAYS=7

RESEND_API_KEY=re_your_api_key_here
MAIL_FROM=noreply@yourdomain.com
FRONTEND_URL=http://localhost:3000

# Host verification
HOST_VERIFICATION_WINDOW_HOURS=24
HOST_VERIFICATION_SWEEP_INTERVAL_MINUTES=1
HOST_VERIFICATION_FAST_WINDOW_MINUTES=10
HOST_VERIFICATION_FAST_INTERVAL_MINUTES=1
HOST_VERIFICATION_SLOW_INTERVAL_MINUTES=5
HOST_VERIFICATION_DNS_PREFIX=_lt-verify
HOST_VERIFICATION_HTTP_PATH=/.well-known/lt-verify.txt
HOST_VERIFY_DNS_TIMEOUT_SECONDS=5
HOST_VERIFY_HTTP_TIMEOUT_SECONDS=10

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# k6 load test execution
K6_IMAGE=grafana/k6:0.57.0
K6_RUNS_DIR=/tmp/loadwhiz-runs
# Docker network for k6 containers. Requires `docker compose up` or `docker network create loadwhiz-network`.
# Leave empty for local Celery workers to use the default bridge network (external targets still work).
K6_DOCKER_NETWORK=loadwhiz-network
K6_CONTAINER_MEMORY=512m
K6_CONTAINER_CPUS=1.0
LOAD_TEST_MAX_CONCURRENT_RUNS=5
LOAD_TEST_SCHEDULED_DISPATCH_INTERVAL_MINUTES=1