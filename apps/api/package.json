{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "poetry run fastapi dev src/main.py --host 0.0.0.0 --port 8000",
    "start": "poetry run fastapi run src/main.py --host 0.0.0.0 --port 8000",
    "build": "node -e \"process.exit(0)\"",
    "check-types": "node -e \"process.exit(0)\"",
    "test": "poetry run pytest",
    "db:migrate": "poetry run alembic upgrade head",
    "db:revision": "poetry run alembic revision --autogenerate",
    "celery:worker": "poetry run celery -A src.workers.celery_app worker --loglevel=info",
    "celery:beat": "poetry run celery -A src.workers.celery_app beat --loglevel=info",
    "celery:dev": "poetry run celery -A src.workers.celery_app worker --beat --loglevel=info",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "openapi:pull": "curl -sf http://localhost:8000/openapi.json -o ../../api.json"
  }
}
